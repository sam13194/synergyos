#!/usr/bin/env python3
"""synergy — AI SysAdmin layer for Linux (proof of concept).
Local-first. Reads real system state, explains it in plain language via Ollama.
"""
import subprocess
import sys
import json
import shutil
import urllib.request

MODEL = "llama3.1:8b"   # cambia por el que tengas: 'qwen2.5:7b', 'mistral', etc.
OLLAMA_URL = "http://localhost:11434/api/generate"


def run(cmd):
    """Ejecuta un comando de solo lectura y devuelve su salida."""
    try:
        return subprocess.run(cmd, capture_output=True, text=True, timeout=15).stdout
    except Exception as e:
        return f"[no disponible: {e}]"


def ask_ollama(prompt):
    """Envía el prompt al modelo local. Sin nube, sin API keys."""
    data = json.dumps({"model": MODEL, "prompt": prompt, "stream": False}).encode()
    req = urllib.request.Request(OLLAMA_URL, data=data,
                                 headers={"Content-Type": "application/json"})
    try:
        with urllib.request.urlopen(req, timeout=120) as r:
            return json.loads(r.read())["response"].strip()
    except Exception as e:
        return f"No pude contactar a Ollama en {OLLAMA_URL} ({e}).\nVerifica: ollama serve / ollama pull {MODEL}"


def collect_state():
    """Recolecta estado real del sistema (solo lectura)."""
    return {
        "disco": run(["df", "-h", "/"]),
        "memoria": run(["free", "-h"]),
        "carga": run(["uptime"]),
        "servicios_fallidos": run(["systemctl", "--failed", "--no-legend"]),
        "errores_recientes": run(["journalctl", "-p", "err", "-n", "30",
                                  "--no-pager", "-o", "short"]),
    }


def cmd_status():
    s = collect_state()
    prompt = f"""Eres un administrador de sistemas Linux senior. Analiza este estado real
de un servidor y responde en español, conciso. Da: (1) un resumen de salud en 1 línea,
(2) las alertas reales que veas (disco, RAM, servicios caídos, errores), (3) acciones
sugeridas numeradas. No inventes datos que no estén abajo.

=== DISCO ===
{s['disco']}
=== MEMORIA ===
{s['memoria']}
=== CARGA ===
{s['carga']}
=== SERVICIOS FALLIDOS ===
{s['servicios_fallidos'] or 'ninguno'}
=== ERRORES RECIENTES (journalctl) ===
{s['errores_recientes'] or 'ninguno'}
"""
    print("Analizando estado del sistema con modelo local...\n")
    print(ask_ollama(prompt))


def cmd_explain(service):
    logs = run(["journalctl", "-u", service, "-n", "40", "--no-pager", "-o", "short"])
    prompt = f"""Eres un administrador de sistemas Linux senior. Explica en español, claro y
breve, qué está pasando con el servicio '{service}' según estos logs reales. Si hay un
error, di la causa probable y cómo resolverlo. No inventes nada fuera de los logs.

=== journalctl -u {service} ===
{logs}
"""
    print(f"Explicando el servicio '{service}'...\n")
    print(ask_ollama(prompt))


def main():
    if not shutil.which("ollama"):
        print("Ollama no está instalado. Instálalo: https://ollama.com")
        sys.exit(1)

    args = sys.argv[1:]
    if not args:
        print("Uso:\n  synergy status              # salud general del sistema\n"
              "  synergy explain <servicio>  # explica un servicio (ej: nginx)")
        sys.exit(0)

    if args[0] == "status":
        cmd_status()
    elif args[0] == "explain" and len(args) > 1:
        cmd_explain(args[1])
    else:
        print("Comando no reconocido. Usa: synergy status | synergy explain <servicio>")


if __name__ == "__main__":
    main()
