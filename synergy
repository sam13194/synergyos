#!/usr/bin/env python3
"""synergy — AI SysAdmin layer for Debian/Ubuntu.
Local-first. Reads real system state, explains it in plain language via Ollama.
"""
import os
import subprocess
import sys
import json
import urllib.request

MODEL       = "llama3.1:8b"   # override with --model: 'qwen2.5:7b', 'mistral', etc.
OLLAMA_HOST = os.environ.get("SYNERGY_HOST", "localhost:11434")
OLLAMA_URL  = f"http://{OLLAMA_HOST}/api/generate"

USAGE = """\
synergy — AI SysAdmin layer for Debian/Ubuntu (local-first, no cloud)

Usage:
  synergy status [--model <name>] [--fast] [--verbose]             AI health summary
  synergy explain <service> [--model <name>] [--fast] [--verbose]  Explain a service
  synergy diagnose <service> [--model <name>] [--fast] [--verbose] Alias for 'explain'

Flags:
  --fast     Smaller prompt (10 log lines, last hour only) — for CPU-only servers
  --verbose  Show each collection step and prompt size
  --model    Override the default model (default: {model})

Examples:
  synergy status
  synergy explain nginx
  synergy explain sshd --model qwen2.5:7b
  synergy diagnose postgresql

  # Point to a remote AI node instead of localhost:
  SYNERGY_HOST=192.168.1.10:11434 synergy status

Default model : {model}
Ollama endpoint: {url}  (override with SYNERGY_HOST env var)
""".format(model=MODEL, url=OLLAMA_URL)


VERBOSE = False
FAST    = False


def vprint(msg):
    if VERBOSE:
        print(f"  \033[2m{msg}\033[0m", flush=True)


def run(cmd, label=None):
    """Run a read-only system command and return its stdout."""
    if label:
        vprint(f"[recolectando] {label}...")
    try:
        return subprocess.run(cmd, capture_output=True, text=True, timeout=15).stdout
    except Exception as e:
        return f"[no disponible: {e}]"


def ask_ollama(prompt, model):
    """Send prompt to local model. No cloud, no API keys."""
    vprint(f"[prompt] {len(prompt)} caracteres → {OLLAMA_URL}")
    vprint(f"[modelo] {model} — esperando respuesta...")
    data = json.dumps({"model": model, "prompt": prompt, "stream": False}).encode()
    req = urllib.request.Request(
        OLLAMA_URL, data=data, headers={"Content-Type": "application/json"}
    )
    try:
        with urllib.request.urlopen(req, timeout=600) as r:
            response = json.loads(r.read())
            vprint(f"[listo] {response.get('eval_count', '?')} tokens generados")
            return response["response"].strip()
    except Exception as e:
        return (
            f"No pude contactar a Ollama en {OLLAMA_URL}.\n"
            f"  Error: {e}\n\n"
            "Verifica:\n"
            "  1. ollama serve          # iniciar el servidor\n"
            f"  2. ollama pull {model}   # descargar el modelo si no lo tienes"
        )


def collect_state():
    """Collect real system state (read-only)."""
    if FAST:
        journal_cmd = ["journalctl", "-p", "err", "-n", "10",
                       "--since", "1 hour ago", "--no-pager", "-o", "short"]
    else:
        journal_cmd = ["journalctl", "-p", "err", "-n", "30", "--no-pager", "-o", "short"]

    return {
        "disco":              run(["df", "-h", "/"], "disco"),
        "memoria":            run(["free", "-h"], "memoria"),
        "carga":              run(["uptime"], "carga del sistema"),
        "servicios_fallidos": run(["systemctl", "--failed", "--no-legend"], "servicios fallidos"),
        "errores_recientes":  run(journal_cmd, "errores recientes (journalctl)"),
    }


def cmd_status(model):
    s = collect_state()
    if FAST:
        prompt = (
            f"Eres un sysadmin Linux. Responde en español, muy breve. "
            f"Da: (1) salud en 1 línea, (2) alertas reales, (3) acciones. "
            f"Solo usa los datos de abajo.\n"
            f"DISCO: {s['disco'].strip()}\n"
            f"RAM: {s['memoria'].strip()}\n"
            f"CARGA: {s['carga'].strip()}\n"
            f"FALLOS: {s['servicios_fallidos'].strip() or 'ninguno'}\n"
            f"ERRORES: {s['errores_recientes'].strip() or 'ninguno'}\n"
        )
    else:
        prompt = f"""Eres un administrador de sistemas Linux senior. Analiza este estado real
de un servidor y responde en español, conciso. Da: (1) un resumen de salud en 1 línea,
(2) las alertas reales que veas (disco, RAM, servicios caídos, errores), (3) acciones
sugeridas numeradas. No inventes datos que no estén abajo.

=== DISCO ===
{s['disco']}
=== MEMORIA ===
{s['memoria']}
=== CARGA ===
{s['carga']}
=== SERVICIOS FALLIDOS ===
{s['servicios_fallidos'] or 'ninguno'}
=== ERRORES RECIENTES (journalctl) ===
{s['errores_recientes'] or 'ninguno'}
"""
    mode = "rápido (--fast): 10 líneas, última hora" if FAST else "completo: 30 líneas"
    vprint(f"[modo] {mode}")
    label = " [modo rápido]" if FAST else ""
    print(f"Analizando estado del sistema con modelo '{model}'{label}...\n")
    print(ask_ollama(prompt, model))


def cmd_explain(service, model):
    if not service:
        print(
            "Error: debes especificar el nombre del servicio.\n"
            "Ejemplo:  synergy explain nginx"
        )
        sys.exit(1)
    logs = run(
        ["journalctl", "-u", service, "-n", "40", "--no-pager", "-o", "short"],
        f"journalctl -u {service}"
    )
    prompt = f"""Eres un administrador de sistemas Linux senior. Explica en español, claro y
breve, qué está pasando con el servicio '{service}' según estos logs reales. Si hay un
error, di la causa probable y cómo resolverlo. No inventes nada fuera de los logs.

=== journalctl -u {service} ===
{logs}
"""
    print(f"Explicando el servicio '{service}' con modelo '{model}'...\n")
    print(ask_ollama(prompt, model))


def parse_args(args):
    """Extract --model and --verbose flags from anywhere in argv."""
    global VERBOSE, FAST
    model = MODEL
    remaining = []
    i = 0
    while i < len(args):
        if args[i] == "--model" and i + 1 < len(args):
            model = args[i + 1]
            i += 2
        elif args[i] in ("--verbose", "-v"):
            VERBOSE = True
            i += 1
        elif args[i] == "--fast":
            FAST = True
            i += 1
        else:
            remaining.append(args[i])
            i += 1
    return remaining, model


def main():
    args = sys.argv[1:]
    if not args or args[0] in ("-h", "--help"):
        print(USAGE)
        sys.exit(0)

    remaining, model = parse_args(args)

    if not remaining:
        print(USAGE)
        sys.exit(0)

    subcmd = remaining[0]

    if subcmd == "status":
        cmd_status(model)
    elif subcmd in ("explain", "diagnose"):
        service = remaining[1] if len(remaining) > 1 else ""
        cmd_explain(service, model)
    else:
        print(f"Comando no reconocido: '{subcmd}'\n")
        print(USAGE)
        sys.exit(1)


if __name__ == "__main__":
    main()
